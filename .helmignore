# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/

# adding below
.venv/
venv/
__pycache__/
*.pyc



# Exclude local Pulumi state or other IDE folders
.pulumi/

# Exclude your local testing scripts
*.sh
*.tar.gz"